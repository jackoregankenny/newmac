# newmac-ui dev tasks. Run from the `ui/` dir:  just <recipe>
# (Install `just` with: brew install just)

set windows-shell := ["bash", "-uc"]

# List recipes
default:
    @just --list

# Build the release binary (what gets installed)
build:
    cargo build --release

# Build the debug binary (fast, what tests use)
dev:
    cargo build

# Run every test in the workspace
test:
    cargo test --workspace

# Format, then lint with warnings-as-errors
lint:
    cargo fmt --all -- --check
    cargo clippy --workspace --all-targets -- -D warnings

# Auto-format
fmt:
    cargo fmt --all

# Regenerate scripts/{catalog,presets}.sh from catalog.toml + flavours/
gen-sh:
    cargo run --release -- catalog gen-sh --out-dir ../scripts

# Fail if the generated scripts are stale vs catalog.toml / flavours (CI)
check-catalog:
    cargo run --release -- catalog gen-sh --out-dir /tmp/newmac-gen
    diff -u ../scripts/catalog.sh /tmp/newmac-gen/catalog.sh
    diff -u ../scripts/presets.sh /tmp/newmac-gen/presets.sh
    @echo "catalog.sh + presets.sh are up to date"

# Print the live popular-Homebrew list (needs network)
brew-refresh:
    cargo run --release -- brew refresh

# Open the picker against a throwaway conf
run:
    cargo run --release -- --conf /tmp/newmac.demo.conf

# Everything CI runs
ci: lint test build check-catalog
