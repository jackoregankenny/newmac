#!/usr/bin/env bash
# ~/.config/borders/bordersrc — JankyBorders: an outline on the focused window.
# Started as a brew service (or by ricing.sh). Restart: brew services restart borders
# Colours come from ~/.config/newmac/theme.sh (run: bash scripts/theme.sh <id>).

# --- Theme (generated by scripts/theme.sh) ---
[ -f "$HOME/.config/newmac/theme.sh" ] && . "$HOME/.config/newmac/theme.sh"
# Fallbacks (Tokyo Night) so borders works before theme.sh has ever run.
: "${C_ACCENT:=0xffbb9af7}"       # focused window outline
: "${C_SURFACE:=0xff24283b}"      # unfocused window outline
: "${C_BORDER_STYLE:=round}"      # round | square (sharp themes set square)

options=(
  "style=$C_BORDER_STYLE"
  width=6.0
  hidpi=on
  "active_color=$C_ACCENT"
  "inactive_color=$C_SURFACE"
)
borders "${options[@]}"
