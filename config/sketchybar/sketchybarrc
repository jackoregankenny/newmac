#!/usr/bin/env bash
# ~/.config/sketchybar/sketchybarrc — themed bar wired to AeroSpace.
# Colours come from ~/.config/newmac/theme.sh (run: bash scripts/theme.sh <id>).
# Reload: brew services restart sketchybar   (or:  sketchybar --reload)

PLUGIN_DIR="$HOME/.config/sketchybar/plugins"

# --- Theme (generated by scripts/theme.sh) ---
[ -f "$HOME/.config/newmac/theme.sh" ] && . "$HOME/.config/newmac/theme.sh"
# Fallbacks (Tokyo Night) so the bar works before theme.sh has ever run.
: "${C_BAR:=0xf01a1b26}"       # translucent bar background
: "${C_SURFACE:=0xff24283b}"   # item backgrounds
: "${C_TEXT:=0xffc0caf5}"      # primary text
: "${C_ACCENT:=0xffbb9af7}"    # focus / highlights

sketchybar --bar \
  height=36 \
  position=top \
  sticky=on \
  blur_radius=30 \
  padding_left=8 \
  padding_right=8 \
  color="$C_BAR"

default=(
  padding_left=5
  padding_right=5
  icon.font="JetBrainsMono Nerd Font:Bold:14.0"
  label.font="JetBrainsMono Nerd Font:Bold:13.0"
  "icon.color=$C_TEXT"
  "label.color=$C_TEXT"
  "background.color=$C_SURFACE"
  background.corner_radius=6
  background.height=24
)
sketchybar --default "${default[@]}"

# --- Left: AeroSpace workspace indicators ---
for sid in 1 2 3 4 5; do
  sketchybar --add item space.$sid left \
    --subscribe space.$sid aerospace_workspace_change \
    --set space.$sid \
      icon="$sid" \
      label.drawing=off \
      script="$PLUGIN_DIR/aerospace.sh" \
      click_script="aerospace workspace $sid"
done

# --- Left: focused app name ---
sketchybar --add item front_app left \
  --subscribe front_app front_app_switched \
  --set front_app \
    icon.drawing=off \
    label.color="$C_ACCENT" \
    background.drawing=off \
    script="$PLUGIN_DIR/front_app.sh"

# --- Right: clock ---
sketchybar --add item clock right \
  --set clock update_freq=10 icon="󰥔" script="$PLUGIN_DIR/clock.sh"

# --- Right: battery ---
sketchybar --add item battery right \
  --subscribe battery system_woke power_source_change \
  --set battery update_freq=120 script="$PLUGIN_DIR/battery.sh"

# --- Initialise + paint ---
sketchybar --update
sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE="$(aerospace list-workspaces --focused 2>/dev/null)"
